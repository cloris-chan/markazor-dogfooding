@inherits LayoutComponentBase
@inject Markazor.Reading.IMarkazorReaderService Reader

<div class="site-shell">
    <MarkazorHead />
    <canvas class="site-signal" aria-hidden="true"></canvas>
    <header class="site-header">
        <a class="site-brand" href="/">@Reader.Site.Name</a>
        <nav aria-label="Primary navigation">
            <a href="/">Home</a>
            <a href="/posts">Posts</a>
            <a href="/notes">Notes</a>
            <a href="/categories">Categories</a>
            <a href="/tags">Tags</a>
            <a href="/archive">Archive</a>
            <a href="/manage">Manage</a>
        </nav>
    </header>

    <main>
        @Body
    </main>

    <PwaUpdatePrompt />
</div>
